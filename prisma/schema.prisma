generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // 🚨 No URL line here anymore!
}

// 📦 Our Snippet shelf blueprint
model Snippet {
  id        Int      @id @default(autoincrement()) 
  title     String
  code      String
  author    String
  language  String?  
  status    String   @default("pending_ai_review") 
  createdAt DateTime @default(now())               
  updatedAt DateTime @updatedAt                    
}