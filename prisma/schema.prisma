generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  
  // 👇 Tells the database: "One user can have many snippets"
  snippets  Snippet[] 
}

// 👇 NEW: The Snippet Shelf
model Snippet {
  id              Int      @id @default(autoincrement())
  content         String   // The raw code the user pastes in
  
  // --- AI Generated Metadata ---
  summary         String   // The 1-sentence explanation
  tags            String   // Storing the JSON array of tags as a string
  vulnerabilities String   // Security warnings
  
  // --- The Owner ---
  userId          Int      // Who owns this snippet?
  user            User     @relation(fields: [userId], references: [id])
  
  createdAt       DateTime @default(now())
}