generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // 🚨 No URL line here anymore!
}

// 📦 Our Snippet shelf blueprint
model Snippet {
  id        Int      @id @default(autoincrement()) 
  title     String
  code      String
  author    String
  language  String?  
  status    String   @default("pending_ai_review") 
  createdAt DateTime @default(now())               
  updatedAt DateTime @updatedAt                    
}

// 🧑‍💻 NEW: Our Guest Registry!
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique  // No two engineers can have the same email
  password  String            // This will hold the shredded (hashed) password
  createdAt DateTime @default(now())
}