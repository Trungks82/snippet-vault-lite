generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Notice: The url line is completely removed here for Prisma 7 compatibility!
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())

  // Tells the database: "One user can have many snippets"
  snippets  Snippet[]
}

// The Unified Snippet Shelf
model Snippet {
  id              Int      @id @default(autoincrement())

  // Data from your NestJS DTO
  title           String
  code            String
  author          String

  // AI Generated Metadata (Optional with '?' for backwards compatibility)
  summary         String?
  tags            String?
  vulnerabilities String?
  analysisStatus  String   @default("PENDING")

  // The Owner (Optional with '?' so it doesn't break your current Postman test)
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}